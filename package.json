{
  "name": "printer-manager",
  "version": "1.0.0",
  "description": "Electron desktop printer manager with Socket.IO",
  "main": "main.js",
  "scripts": {
    "start": "electron-forge start",
    "dev": "electron . --inspect=5858",
    "package": "electron-forge package",
    "build-info": "node build-installer.js",
    "make-installer": "node create-installer.js",
    "build": "npm run package && npm run build-info && npm run make-installer",
    "window": "electron-forge make",
    "mac": "electron-forge make --makers=@electron-forge/maker-dmg"
  },
  "keywords": [
    "electron",
    "printer",
    "socket.io"
  ],
  "author": "Printer Manager",
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "electron": "^29.0.0",
    "electron-installer-windows": "^3.0.0",
    "electron-packager": "^17.1.2"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1",
    "express": "^4.18.2",
    "socket.io": "^4.5.4",
    "socket.io-client": "^4.5.4"
  }
}
